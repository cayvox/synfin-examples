# Copy this file to .env and fill in your key.
#
#   cp .env.example .env
#
# Get a free key at https://portal.synfin.xyz (it carries your rate limit and
# your fee configuration). The key is shown once at creation.
SYNFIN_API_KEY=sk_live_your_key_here

# Optional: the Canton party your integrator fee would settle to, and your fee
# in basis points (0 to the cap). Leave the fee unset to quote fee-less.
# SYNFIN_FEE_RECIPIENT=yourparty::1220...
# SYNFIN_FEE_BPS=30

# Only needed by src/swap.mjs: the taker party that sends the deposit and
# receives the payout. This is YOUR user's Canton party.
# SYNFIN_TAKER_PARTY=yourparty::1220...
